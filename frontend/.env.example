EXPO_PUBLIC_API_URL=http://localhost:8000

# Web client — Application type: "Web application"
# Authorized redirect URIs: http://localhost:8081 and https://auth.expo.io/@<username>/activity-tracker
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Android client — Application type: "Android"
# Package name: host.exp.exponent (for Expo Go) or your app's package name for standalone
# SHA-1: run `npx expo credentials:manager` or get from Google Play Console
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# iOS client — Application type: "iOS" (only needed for standalone iOS builds)
# Bundle ID: your app's bundle identifier
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
